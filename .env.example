# API base for axios/fetch. Leave unset or empty so /api/* uses the same host as the
# page (required for ngrok → Caddy). Set to http://localhost:8080 only if you call the
# backend directly from the browser (not via Vite proxy or gateway).
# VITE_API_URL=http://localhost:8080
#
# Vite dev only: where to proxy /api (default gateway 8181). Use http://localhost:8080 if gateway is not running.
# VITE_DEV_PROXY_TARGET=http://localhost:8181
VITE_AUTH_TIMEOUT_MS=10000
# Optional; defaults to VITE_API_URL then same-origin when empty.
# VITE_AUTH_SERVICE_URL=
