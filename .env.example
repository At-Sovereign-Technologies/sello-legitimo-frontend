# Guía de despliegue: docs/guia-puesta-en-marcha.md
#
# Base del API (Axios/fetch). Déjala sin definir o vacía para que /api/* use el mismo
# host que la página (necesario con ngrok → Caddy). Solo usa URL absoluta al backend
# si el navegador debe llamarle directo (no recomendado con HTTPS en ngrok).
# VITE_API_URL=http://localhost:8080
#
# Solo Vite (desarrollo): a dónde reenviar el proxy /api (por defecto gateway 8181).
# Si no tienes gateway, usa p. ej. http://localhost:8080
# VITE_DEV_PROXY_TARGET=http://localhost:8181
VITE_AUTH_TIMEOUT_MS=10000
# Opcional; si está vacío, misma regla que VITE_API_URL (origen relativo).
# VITE_AUTH_SERVICE_URL=
